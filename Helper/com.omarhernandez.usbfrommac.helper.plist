<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- launchd plist para SMAppService.daemon(plistName:).
	     Va embebido en la app en: Contents/Library/LaunchDaemons/<este archivo>.
	     El ejecutable del helper va en: Contents/MacOS/UsbFromMacHelper.
	     (El cableado de copia + firma se hace en Fase 2 con tu Developer ID.) -->
	<key>Label</key>
	<string>com.omarhernandez.usbfrommac.helper</string>
	<key>BundleProgram</key>
	<string>Contents/MacOS/UsbFromMacHelper</string>
	<key>MachServices</key>
	<dict>
		<key>com.omarhernandez.usbfrommac.helper</key>
		<true/>
	</dict>
	<key>AssociatedBundleIdentifiers</key>
	<array>
		<string>com.omarhernandez.usbfrommac</string>
	</array>
</dict>
</plist>
