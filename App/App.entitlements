<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- WinUSB Mac NO puede ir en sandbox: necesita acceso a disco crudo
	     (DiskArbitration / formateo) que el sandbox del App Store prohíbe.
	     Por eso se distribuye notarizada FUERA del Mac App Store. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!-- Phase 5: si se cargan dylibs de wimlib de terceros con hardened runtime,
	     puede requerirse com.apple.security.cs.disable-library-validation. -->
</dict>
</plist>
